# ── Database (Postgres) ───────────────────────────────────────────────────
# Postgres connection string. On Vercel use a POOLED url (e.g. Neon/Supabase
# pooler, or add ?pgbouncer=true). For a local DB, point this at any Postgres
# (a free Neon dev branch or a Docker postgres both work).
#   Neon example: postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/medpull?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/medpull?sslmode=require"

# Public site origin — used for canonical/OG URLs.
NEXT_PUBLIC_SITE_URL="https://medpull.org"

# ── Analytics (p1-5) ──────────────────────────────────────────────────────
# PostHog project API key. Analytics are a NO-OP when unset.
# TODO(steve): create PostHog account (checklist p1-4) and fill these in.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Admin dashboard (p2-1) ────────────────────────────────────────────────
# Password for /admin. Required for the admin dashboard to be accessible.
ADMIN_PASSWORD=""

# ── Intern dashboard (p5-2) ───────────────────────────────────────────────
# Password for /intern. Required for the intern dashboard to be accessible.
INTERN_PASSWORD=""

# ── Calendar embed (p2-6) ─────────────────────────────────────────────────
# Your Cal.com scheduling link, e.g. "https://cal.com/your-team/intro-call".
# The booking page shows a graceful empty state when unset.
# TODO(steve): set up Cal.com (checklist p2-5) and fill in.
CAL_COM_URL=""

# ── Twilio SMS (p3-1) ─────────────────────────────────────────────────────
# DRY_RUN defaults to ON: messages are logged to the DB/console, not sent.
# Set SMS_DRY_RUN="false" AND provide real credentials to actually send.
# TODO(steve): complete A2P 10DLC registration (checklist p0-2) first.
SMS_DRY_RUN="true"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Intake encryption (p4-4) ──────────────────────────────────────────────
# 32-byte key, base64-encoded, for AES-256-GCM field-level encryption of
# sensitive intake fields. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTAKE_ENCRYPTION_KEY=""

# ── Quiet hours (p3-3) ────────────────────────────────────────────────────
# Default timezone for leads with no known timezone.
DEFAULT_LEAD_TIMEZONE="America/Los_Angeles"
